# MT8183 Burnet Hardware Bridge Environment
BRIDGE_PATH="$HOME/.local/share/nix-burnet-bridge"

# Pathing
export LD_LIBRARY_PATH="$BRIDGE_PATH:$BRIDGE_PATH/dri:/usr/lib/aarch64-linux-gnu:/lib/aarch64-linux-gnu:$LD_LIBRARY_PATH"
export LIBGL_DRIVERS_PATH="$BRIDGE_PATH/dri"
export GBM_DRIVERS_PATH="$BRIDGE_PATH/dri"
export LIBVA_DRIVERS_PATH="$BRIDGE_PATH/dri"

# Hardware Sauce
export WLR_RENDERER=gles2
export QT_XCB_GL_INTEGRATION=xcb_egl
export __EGL_VENDOR_LIBRARY_FILENAMES="/usr/share/glvnd/egl_vendor.d/50_mesa.json"

# This tells Qt to try Wayland first, but fallback to X11 (XCB)
export QT_QPA_PLATFORM="wayland;xcb"

# Video Decode
export LIBVA_DRIVER_NAME=mediatek

# Don't lose Nix tools when using the GPU bridge
export PATH="/nix/store/bslwamwpnk894p9bvmxmara834wxg87n-home-manager/bin:$HOME/.nix-profile/bin:$PATH"
